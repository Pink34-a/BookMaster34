<Window x:Class="BookMaster34.View.Windows.EditCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookMaster34.View.Windows"
        mc:Ignorable="d"  
      Title="Редактирование клиента" Height="500" Width="800"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" >
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10 10 10 10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ИД:" HorizontalAlignment="Stretch"/>
            <TextBox Background="LightGray" Name="IDclienTb" Grid.Column="2" IsReadOnly="True" Width="200" HorizontalAlignment="Right" />

            <TextBlock Text="Имя клиента:" Grid.Row="2"/>
            <TextBox Name="ClientNameTb" Grid.Column="2" Grid.Row="2" Width="200" HorizontalAlignment="Right" Text="{Binding Name}"/>

            <TextBlock Text="Адрес клиента:" Grid.Row="4"/>
            <TextBox Name="AddressClientTb" Grid.Column="2" Grid.Row="4" Width="200" HorizontalAlignment="Right" Text="{Binding Address}"/>

            <TextBlock Text="Почтовый индекс:" Grid.Row="6"/>
            <TextBox Name="ZipCityTb" Grid.Column="2" Grid.Row="6" Width="100" HorizontalAlignment="Left" Text="{Binding Zip}"/>
            <ComboBox Name="ZipCityCmb" Grid.Column="2" Grid.Row="6" SelectedIndex="0" DisplayMemberPath="Name" SelectedValuePath="Id" Width="100" HorizontalAlignment="Right" />

        </Grid>
        <Grid Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="50"/>

            </Grid.RowDefinitions>

            <TextBlock Text="Телефон:" Grid.Row="1" HorizontalAlignment="Left"/>
            <TextBox Name="PhoneCostomerTb" Grid.Column="0" Grid.Row="1" Width="220" HorizontalAlignment="Right" Text="{Binding Phone}"/>

            <TextBlock Text="Почта:" Grid.Row="3"/>
            <TextBox Name="EmailCostomerTb" Grid.Column="0" Grid.Row="3" Width="220" HorizontalAlignment="Right" Text="{Binding Email}"/>

            <Grid Grid.Row="5">
                <Button Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click"  Grid.Row="6"  Width="130" HorizontalAlignment="Left"/>
                <Button Name="AddBtn" Content="Добавить" Click="AddBtn_Click"  Grid.Row="6"  Width="130" HorizontalAlignment="Left"/>
                <Button Name="EditBtn" Content="Редактировать" Click="EditBtn_Click"  Grid.Row="6"  Width="140" HorizontalAlignment="Left"/>
                <Button Name="CancelBtn" Content="Отмена" Width="130" HorizontalAlignment="Left"  Click="CancelBtn_Click"  Margin="208,0,0,0"/>
            </Grid>

        </Grid>
    </Grid>
</Window>
