<Page x:Class="BookMaster34.View.Pages.BrowseCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BookMaster34.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1004" d:DesignWidth="1920"
      Title="Просмотр книг">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"></ColumnDefinition>
            <ColumnDefinition Width="20"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
<!--Панель поиска-->
        <Border Background="{DynamicResource Gray}">
        <Grid Margin="20" Background="{DynamicResource Gray}">
        
        <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
                
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                
                
            </Grid.ColumnDefinitions>
                
             <Image Grid.ColumnSpan="3"  Source="/Resources/logo.png" />
                
            <TextBlock Grid.Row="2" Text="Название:"/>
            <TextBox Grid.Row="2" Grid.Column="2" Name="BookTitleTb"/>

            <TextBlock Grid.Row="4" Text="Авторы:"/>
            <TextBox Grid.Row="4" Grid.Column="2" Name="BookAuthorsTb"/>

            <TextBlock Grid.Row="6" Text="Жанры:"/>
            <TextBox Grid.Row="6" Grid.Column="2" Name="BookSubjectsTb"/>

            <Button Name="SearchBtn" Grid.Row="8" Grid.Column="2" Content="Поиск" Click="SearchBtn_Click"/>
                
                
        </Grid>
        </Border>
            <Grid Grid.Column="2" Name="SearchResultsGrid" Visibility="Collapsed" Margin="0 20 20 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            
            <!--Результаты поиска-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <ListView Name="BookAuthorsLV"
                    SelectionChanged="BookAuthorsLV_SelectionChanged">

                    <!--Создаем заголовки для таблицы-->
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Название"
                            DisplayMemberBinding="{Binding Title}"/>
                            
                            <GridViewColumn Header="Авторы"
                            DisplayMemberBinding="{Binding Authors}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Страница"/>

                    <Button Name="PreviousPageBtn" Grid.Column="2" Content="&lt;" Click="PreviousPageBtn_Click"/>

                    <TextBox Name="CurrentPageTb" Grid.Column="4" TextChanged="CurrentPageTb_TextChanged"/>

                    <Button Name="NextPageBtn" Grid.Column="6" Content="&gt;" Click="NextPageBtn_Click"/>

                    <TextBlock Name="TotalPagesTbl" Grid.Column="8" Text="из 4" />
                    <TextBlock Name="TotalBooksTbl" Grid.Column="12" Text="{Binding ElementName=BookAuthorsLV, Path=Items.Count, StringFormat={}{0} книг найдено}"/>


                </Grid>
            </Grid>
            <!--Изменение размеров гридов-->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Margin="0 10"/>
            <!--Информация о выбранной книге-->
            <Grid Grid.Row="2" Name="BookDetailsGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions> 
                <!--Текстовая иинформация-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="30" Text="{Binding Title}"/>
                    <TextBlock Grid.Row="2" Text="{Binding Subtitle}"/>
                    <!--Реализация гиперссылки-->
                    <TextBlock Grid.Row="4"> 
                        <Hyperlink Name="BookAuthorsDetailsHl" Click="BookAuthorsDetailsHl_Click">
                            <TextBlock Text="{Binding Authors}"/>
                        </Hyperlink>
                    </TextBlock> 
                    <TextBlock Grid.Row="6" Text="{Binding FirstPublishDate,StringFormat={}Год первой публикации: {0:yyyy}}"/>
                    <TextBlock Grid.Row="8" FontWeight="SemiBold" Text="Описание"/>
                    <ScrollViewer Grid.Row="10" Padding="0 0 5 0" VerticalScrollBarVisibility="Auto"></ScrollViewer>
                    <TextBlock Grid.Row="10" Text="{Binding Description}"/>
                    <TextBlock Grid.Row="12"  FontWeight="SemiBold" Text="Жанр"/>
                    <TextBlock Grid.Row="14" Text="{Binding Subjects}"/>
                </Grid>
                <!--Слайдер изображений-->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Image  Grid.ColumnSpan="3" Stretch="Fill" Source="/Resources/booklogo.jpg" />
                    <Button Grid.Row="2" Content="&lt;"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="&gt;"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
